# Security headers (PHI-46, PRD §11.4). Served by Cloudflare Pages.
# The script-src hashes pin the site's TWO inline scripts:
#   GPoKB… = the FR-08 theme snippet (Shell.astro, every page)
#   SIi6D… = the reading-pane scroll-mask observer (note/log pages)
# If either changes, recompute sha256(base64) of the exact built
# <script> bodies across dist/**/*.html — all of them, not just home.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-GPoKBNhT59nkFtJSv49GJPwxuKMFId3KuVUZ5AmqxZA=' 'sha256-SIi6DAedYVa9OlhcTRSKfHg0eGE/bKnMtzZaOuXX4YY='; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; media-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=()
