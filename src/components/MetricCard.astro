---
/**
 * Metric card (FR-35/FR-39). `value: pending` renders as an em-dash with
 * its label — visible, honest, unfilled. The source line is the receipt
 * and renders either way (§4.2, ADR 0004).
 */
interface Props {
  label: string;
  value: string | number;
  source: string;
}

const { label, value, source } = Astro.props;
const pending = String(value).trim().toLowerCase() === 'pending';
---

<div class="rounded-[10px] border border-line bg-surface p-4">
  <p class="font-mono text-xs tracking-[0.08em] text-mist">{label}</p>
  <p class="mt-1 font-display text-2xl font-medium text-ink">{pending ? '—' : value}</p>
  <p class="mt-1 font-mono text-[10px] leading-snug text-mist">
    {pending ? 'pending · ' : ''}{source}
  </p>
</div>
