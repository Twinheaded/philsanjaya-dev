---
import { getCollection, render } from 'astro:content';
import Sheet from '../../layouts/Sheet.astro';
import NotePane from '../../components/NotePane.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  for (const n of notes) {
    if (/^\d+$/.test(n.id)) {
      throw new Error(`Note filename "${n.id}.md" collides with pagination routes — rename it`);
    }
  }
  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' });
---

<Sheet
  title={`${note.data.title} — Philipus Sanjaya`}
  description={note.data.summary ?? `A note by Philipus Sanjaya: ${note.data.title}`}
>
  <article class="flex h-full min-h-0 flex-col p-5 md:p-12">
    <header class="shrink-0">
      <a href="/notes" class="font-mono text-xs text-mist hover:text-ink">&larr; notes</a>
      <p class="mt-4 font-mono text-xs tracking-[0.08em] text-mist">
        03 — note · <time datetime={note.data.date.toISOString().slice(0, 10)}
          >{formatDate(note.data.date)}</time
        >
      </p>
      <h1 class="mt-2 max-w-2xl font-display text-[28px] leading-tight font-medium">
        {note.data.title}
      </h1>
    </header>
    <NotePane label={note.data.title}>
      <div class="prose-md mt-4 pb-8">
        <Content />
      </div>
    </NotePane>
  </article>
</Sheet>
