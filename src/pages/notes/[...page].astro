---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import Desk from '../../layouts/Desk.astro';

export const getStaticPaths = (async ({ paginate }) => {
  const notes = (await getCollection('notes')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  );
  // FR-40: the list fits the zone; beyond six entries it paginates.
  return paginate(notes, { pageSize: 6 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<Desk
  title="Notes — Philipus Sanjaya"
  description="Short technical notes by Philipus Sanjaya."
  zone="notes"
  notesPage={page}
/>
