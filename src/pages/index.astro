---
import Shell from '../layouts/Shell.astro';
---

<Shell
  title="Phil Sanjaya"
  description="Portfolio of Phil Sanjaya — software engineering and data science student building agent simulations, ML pipelines, and ICS security tooling."
>
  <section class="flex h-full flex-col justify-center p-5 md:p-12">
    <p class="font-mono text-xs tracking-[0.08em] text-signal">philsanjaya.dev — built in public</p>
    <h1 class="mt-3 font-display text-[clamp(2.5rem,6vw,4rem)] leading-tight font-medium">
      Phil Sanjaya
    </h1>
    <p class="mt-4 max-w-xl text-mist">
      Software engineering and data science student at Swinburne, Melbourne. I build agent
      simulations, ML pipelines, and ICS security tooling — and I'm looking for internships and
      graduate roles.
    </p>
    <div class="mt-8 flex gap-4">
      <a
        href="/projects"
        class="rounded-[10px] border border-line px-5 py-2 text-sm transition-colors duration-150 ease-out hover:border-signal"
        >View projects</a
      >
      <a
        href="/about"
        class="rounded-[10px] border border-line px-5 py-2 text-sm transition-colors duration-150 ease-out hover:border-signal"
        >About me</a
      >
    </div>
  </section>
</Shell>
