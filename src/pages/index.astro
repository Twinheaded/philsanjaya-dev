---
import Shell from '../layouts/Shell.astro';
---

<Shell
  title="Phil Sanjaya"
  description="Portfolio of Phil Sanjaya — software engineering and data science student building agent simulations, ML pipelines, and ICS security tooling."
>
  <section class="relative flex h-full flex-col justify-center p-5 md:p-12">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <canvas id="agent-canvas" class="h-full w-full"></canvas>
    </div>
    <div class="relative">
      <p class="font-mono text-xs tracking-[0.08em] text-signal-text">
        philsanjaya.dev — built in public
      </p>
      <h1 class="mt-3 font-display text-[clamp(2.5rem,6vw,4rem)] leading-tight font-medium">
        Phil Sanjaya
      </h1>
      <p class="mt-4 max-w-xl text-mist">
        Software engineering and data science student at Swinburne, Melbourne. I build agent
        simulations, ML pipelines, and ICS security tooling — and I'm looking for internships and
        graduate roles.
      </p>
      <div class="mt-8 flex gap-4">
        <a
          href="/projects"
          class="rounded-[10px] border border-line bg-surface px-5 py-2 text-sm hover:border-signal motion-safe:transition-colors motion-safe:duration-150 motion-safe:ease-out"
          >View projects</a
        >
        <a
          href="/about"
          class="rounded-[10px] border border-line bg-surface px-5 py-2 text-sm hover:border-signal motion-safe:transition-colors motion-safe:duration-150 motion-safe:ease-out"
          >About me</a
        >
      </div>
    </div>
    <div
      class="absolute bottom-5 left-5 flex items-center gap-3 md:bottom-8 md:left-12"
    >
      <p id="agent-readout" class="font-mono text-xs text-mist"></p>
      <!-- FR-15: touch-reachable debug toggle; `d` does the same. -->
      <button
        id="agent-debug"
        type="button"
        aria-pressed="false"
        aria-label="Toggle steering debug overlay"
        class="cursor-pointer rounded border border-line px-1.5 py-0.5 font-mono text-[10px] text-mist hover:text-ink aria-pressed:border-signal aria-pressed:text-ink"
        >d</button
      >
    </div>

    <script>
      import { mountAgents, type IslandController } from '../islands/agents/engine';
      import { renderReadout } from '../islands/agents/readout';

      let island: IslandController | null = null;

      function mount(): void {
        island?.destroy();
        island = null;
        const canvas = document.getElementById('agent-canvas') as HTMLCanvasElement | null;
        const readout = document.getElementById('agent-readout');
        if (!canvas || !readout) return;
        // Home: wander, the §10 default state; `d`/button toggles the overlay.
        island = mountAgents(canvas, (data) => renderReadout(readout, data), {
          behaviour: 'wander',
          debugButtonId: 'agent-debug',
        });
      }

      // Run once now (on a cold load astro:page-load may already have
      // fired before this module finished loading) and after every swap.
      mount();
      document.addEventListener('astro:page-load', mount);
    </script>
  </section>
</Shell>
