---
import Shell from '../layouts/Shell.astro';
---

<Shell
  title="Not found — Phil Sanjaya"
  description="That page does not exist. The agents have scattered; here is the way home."
>
  <section class="relative flex h-full flex-col items-center justify-center p-5 text-center md:p-12">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <canvas id="notfound-canvas" class="h-full w-full"></canvas>
    </div>
    <div class="relative">
      <p class="font-mono text-xs tracking-[0.08em] text-signal-text">error 404</p>
      <h1 class="mt-3 font-display text-[clamp(2.5rem,6vw,4rem)] leading-tight font-medium">
        Nothing here
      </h1>
      <p class="mx-auto mt-4 max-w-md text-mist">
        That page does not exist — the agents have scattered from the centre. The maths is real;
        the joke is intended.
      </p>
      <div class="mt-8 flex justify-center gap-4">
        <a
          href="/"
          class="rounded-[10px] border border-line bg-surface px-5 py-2 text-sm hover:border-signal motion-safe:transition-colors motion-safe:duration-150 motion-safe:ease-out"
          >Back home</a
        >
        <a
          href="/projects"
          class="rounded-[10px] border border-line bg-surface px-5 py-2 text-sm hover:border-signal motion-safe:transition-colors motion-safe:duration-150 motion-safe:ease-out"
          >View projects</a
        >
      </div>
    </div>
    <p
      id="notfound-readout"
      class="absolute bottom-5 left-5 font-mono text-xs text-mist md:bottom-8 md:left-12"
    >
    </p>

    <script>
      import { mountAgents, type IslandController } from '../islands/agents/engine';
      import { renderReadout } from '../islands/agents/readout';

      let island: IslandController | null = null;

      function mount(): void {
        island?.destroy();
        island = null;
        const canvas = document.getElementById('notfound-canvas') as HTMLCanvasElement | null;
        const readout = document.getElementById('notfound-readout');
        if (!canvas || !readout) return;
        // 404: flee from the screen centre — chaos as the joke (§10).
        island = mountAgents(canvas, (data) => renderReadout(readout, data), {
          behaviour: 'flee',
          fleeFromCenter: true,
        });
      }

      mount();
      document.addEventListener('astro:page-load', mount);
    </script>
  </section>
</Shell>
