---
import { getCollection, render } from 'astro:content';
import Sheet from '../../layouts/Sheet.astro';
import NotePane from '../../components/NotePane.astro';
import { SITE } from '../../lib/site';

export async function getStaticPaths() {
  const entries = await getCollection('buildlog');
  for (const e of entries) {
    if (/^\d+$/.test(e.id)) {
      throw new Error(`Build-log filename "${e.id}.md" collides with pagination routes — rename it`);
    }
  }
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' });
---

<Sheet
  title={`${entry.data.title} — build log — Philipus Sanjaya`}
  description={`Build log entry ${String(entry.data.entry).padStart(2, '0')}: ${entry.data.title}`}
>
  <article class="flex h-full min-h-0 flex-col p-5 md:p-12">
    <!-- A notebook page (§10): LOG number, date, milestone in mono micro over
         a ruled line; commit chips are the receipts (FR-23). -->
    <header class="doc-cardhead shrink-0">
      <a href="/log" class="font-mono text-xs text-ink-soft hover:text-ink">&larr; build log</a>
      <p class="doc-cardhead__meta">
        <span>LOG.{String(entry.data.entry).padStart(2, '0')}</span>
        <time datetime={entry.data.date.toISOString().slice(0, 10)}
          >{formatDate(entry.data.date)}</time
        >
        <span>{entry.data.milestone}</span>
      </p>
      <h1 class="mt-2 max-w-2xl font-display text-[28px] leading-tight font-medium">
        {entry.data.title}
      </h1>
      {
        entry.data.commits.length > 0 && (
          <p class="mt-3 flex flex-wrap gap-2">
            {entry.data.commits.map((sha) => (
              <a
                href={`${SITE.repoUrl}/commit/${sha}`}
                class="chip rounded border border-paper-edge px-1.5 py-0.5 font-mono text-[11px] text-ink-soft"
              >
                {sha}
              </a>
            ))}
          </p>
        )
      }
    </header>
    <NotePane label={entry.data.title}>
      <div class="prose-md mt-4 pb-8">
        <Content />
      </div>
    </NotePane>
  </article>
</Sheet>

<style>
  .chip:hover {
    border-color: var(--copper);
    color: var(--ink);
  }
</style>
