---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import Desk from '../../layouts/Desk.astro';

export const getStaticPaths = (async ({ paginate }) => {
  const entries = (await getCollection('buildlog')).sort((a, b) => b.data.entry - a.data.entry);
  // FR-50: four entries per page keeps the notebook within the zone; older
  // entries paginate rather than clip out of reach.
  return paginate(entries, { pageSize: 4 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<Desk
  title="Build log — Philipus Sanjaya"
  description="How this site is being designed and built: decisions, trade-offs, and commit receipts."
  zone="log"
  logPage={page}
/>
