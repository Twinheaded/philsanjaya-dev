---
/**
 * An experiment document (§10) — a physical engineering document on the desk:
 * title block (§9-styled), abstract, the Problem / Idea / Result write-up from
 * the markdown body, figure plates (M8 fills the architecture plate per §11),
 * the honest-metrics ruled table, and links. One scrolling sheet — the M4/M6
 * chaptered slide deck is retired; the camera (desk.ts) owns all motion.
 *
 * Voice rule (§10): every word of prose comes from the content file; gaps are
 * flagged TODO(phil-voice) in the markdown, never filled in here.
 */
import { getCollection, render } from 'astro:content';
import Sheet from '../../layouts/Sheet.astro';
import DocTitleBlock from '../../components/document/DocTitleBlock.astro';
import FigurePlate from '../../components/document/FigurePlate.astro';
import MetricsTable from '../../components/document/MetricsTable.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => data.status === 'published');
  // FR-20 fails loudly: Astro's loader would otherwise only warn and
  // silently drop one of two entries sharing a slug.
  const seen = new Set<string>();
  for (const p of projects) {
    if (seen.has(p.data.slug)) {
      throw new Error(`Duplicate project slug "${p.data.slug}" — every project needs its own`);
    }
    seen.add(p.data.slug);
  }
  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const d = project.data;

/** FIG numbering: 01 is always the architecture plate; media follows. */
const demoFig = 2;
---

<Sheet title={`${d.title} — Philipus Sanjaya`} description={d.summary} ogImage={`/og/${d.slug}.png`}>
  <!-- The sheet clips (overflow:hidden) and the page supplies the one
       sanctioned contained scroll (§7.5) — the whole document, title block
       included, scrolls as one paper. tabindex: a scrollable region must be
       keyboard-operable (WCAG 2.1.1, repo convention). -->
  <article class="doc flex h-full min-h-0 flex-col">
    <div class="panel-scroll min-h-0 flex-1 p-5 md:p-12" tabindex="0">
    <p>
      <a href="/projects" class="font-mono text-xs text-ink-soft hover:text-ink"
        >&larr; experiments</a
      >
    </p>

    <DocTitleBlock
      expNo={d.expNo}
      title={d.title}
      period={d.period}
      status={d.status}
      stack={d.stack}
    />

    <!-- The abstract: the card's one-liner and the research question (both
         frontmatter voice copy), opening the document like a report head. -->
    <p class="doc__abstract">{d.summary}</p>
    {d.question && <p class="doc__question">{d.question}</p>}

    <div class="prose-md doc__body">
      <Content />
    </div>

    <!-- FIG.01 — the §11 exploded architecture diagram lands here in M8;
         until then the reserved plate. A document may inline its own diagram
         in the body (AEGISX does) — the plate still reserves the §11 redraw. -->
    {!d.diagram && <FigurePlate no={1} caption="architecture" empty />}

    {
      d.hero && (
        <FigurePlate no={demoFig} caption="demonstration">
          {/\.(webm|mp4)$/i.test(d.hero) ? (
            /* FR-38: lazy hero — preload="none" means nothing downloads until
               the user presses play; the poster stands in. The old
               chapter-gated autoplay retired with the chapter deck — a
               document on the desk stays still until asked. */
            <video
              src={d.hero}
              poster={d.heroPoster}
              controls
              muted
              loop
              playsinline
              preload="none"
              aria-label={`${d.title} — demonstration video`}
            />
          ) : (
            <img
              src={d.hero}
              alt={`${d.title} — demonstration`}
              loading="lazy"
              decoding="async"
            />
          )}
        </FigurePlate>
      )
    }

    <section class="doc__section" aria-labelledby="doc-metrics">
      <h2 id="doc-metrics" class="doc__h2">Honest metrics</h2>
      <MetricsTable metrics={d.metrics} />
    </section>

    {
      d.links.length > 0 && (
        <section class="doc__section" aria-labelledby="doc-links">
          <h2 id="doc-links" class="doc__h2">Links</h2>
          <ul class="doc__links">
            {d.links.map((l) => (
              <li>
                <a href={l.url} class="font-mono text-xs text-copper-deep underline underline-offset-4">
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
    </div>
  </article>
</Sheet>
