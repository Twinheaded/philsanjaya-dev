---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { PANELS, panelIndex } from '../lib/panels';
// Preload the above-the-fold latin subsets so the hero text paints without a
// font swap (FR-NFR fonts preloaded, §8). Vite fingerprints these URLs.
import archivoUrl from '@fontsource/archivo/files/archivo-latin-500-normal.woff2?url';
import instrumentUrl from '@fontsource/instrument-sans/files/instrument-sans-latin-400-normal.woff2?url';
import monoUrl from '@fontsource/ibm-plex-mono/files/ibm-plex-mono-latin-400-normal.woff2?url';

interface Props {
  title: string;
  description: string;
  /** Path to the OG/Twitter image for this page (defaults to the site card). */
  ogImage?: string;
}

const { title, description, ogImage = '/og/default.png' } = Astro.props;
const current = panelIndex(Astro.url.pathname);

// Canonical + social URLs from the configured site (PRD §7.80–84). Astro.site
// is the pages.dev host until M5 flips it to the production domain.
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href={archivoUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={instrumentUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={monoUrl} as="font" type="font/woff2" crossorigin />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <!-- Open Graph / Twitter (FR-82). -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="philsanjaya.dev" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script is:inline>
      // FR-08: apply the stored theme before first paint, and re-apply after
      // every view-transition swap (the swap replaces <html> attributes).
      // data-js marks that scripting ran, revealing JS-only controls (FR-74).
      (() => {
        const apply = () => {
          document.documentElement.dataset.js = '';
          const stored = localStorage.getItem('theme');
          if (stored === 'light' || stored === 'dark') {
            document.documentElement.dataset.theme = stored;
          } else {
            delete document.documentElement.dataset.theme;
          }
        };
        apply();
        document.addEventListener('astro:after-swap', apply);
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-surface focus:px-4 focus:py-2 focus:text-ink"
      >Skip to content</a
    >
    <!-- Mobile secondary menu: the tab bar stays five items (§9.4), so the
         theme toggle (FR-08) lives in a settings disclosure below 768px. -->
    <div class="js-only fixed top-4 right-4 z-40 md:hidden">
      <button
        id="settings-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="settings-menu"
        class="cursor-pointer rounded-[10px] border border-line bg-surface px-3 py-1.5 font-mono text-xs text-mist"
        >settings</button
      >
      <div
        id="settings-menu"
        hidden
        class="absolute right-0 mt-2 rounded-[10px] border border-line bg-surface p-3"
      >
        <button
          type="button"
          class="theme-toggle cursor-pointer font-mono text-xs whitespace-nowrap text-mist hover:text-ink motion-safe:transition-colors motion-safe:duration-150 motion-safe:ease-out"
          >theme: auto</button
        >
      </div>
    </div>
    <div class="relative flex h-dvh flex-col-reverse md:flex-row">
      <nav
        class="rail flex h-14 shrink-0 items-stretch border-t border-line md:h-auto md:w-[200px] md:flex-col md:border-t-0 md:border-r md:p-6"
        aria-label="Main"
      >
        <a href="/" class="brand hidden items-center gap-2 md:flex">
          <svg viewBox="0 0 32 32" class="h-4 w-4" aria-hidden="true">
            <circle cx="12" cy="16" r="6" fill="var(--signal)"></circle>
            <path
              d="M18 16h10"
              stroke="var(--signal)"
              stroke-width="3"
              stroke-linecap="round"></path>
          </svg>
          <span class="font-mono text-xs tracking-[0.08em] text-ink">philsanjaya.dev</span>
        </a>
        <ol class="flex flex-1 items-stretch justify-around md:mt-10 md:flex-col md:justify-start md:gap-2">
          {
            PANELS.map((p, i) => (
              <li class="flex flex-1 md:flex-none">
                <a
                  href={p.href}
                  aria-current={i === current ? 'page' : undefined}
                  class="nav-item flex flex-1 flex-col items-center justify-center gap-0.5 text-mist md:flex-row md:justify-start md:gap-3 md:py-1"
                >
                  <span class="num font-mono text-[10px] md:text-xs">{p.num}</span>
                  <span class="text-xs md:text-sm">{p.label}</span>
                </a>
              </li>
            ))
          }
        </ol>
        <div class="js-only hidden md:block">
          <button
            type="button"
            class="theme-toggle cursor-pointer font-mono text-xs text-mist hover:text-ink motion-safe:transition-colors motion-safe:duration-150 motion-safe:ease-out"
            >theme: auto</button
          >
          <p class="mt-3 font-mono text-xs text-mist">
            <span aria-hidden="true">&larr; &rarr; move</span>
            <span class="sr-only">Use the left and right arrow keys to move between panels</span>
          </p>
        </div>
      </nav>
      <main id="main" class="stage min-h-0 min-w-0 flex-1 overflow-hidden" transition:name="stage">
        <slot />
      </main>
      <!-- FR-09: keycap indicators sit low in the stage and light for 150ms
           on an actual arrow keypress, teaching the shortcut silently.
           Decorative + desktop-only (mobile navigates by swipe). -->
      <div
        id="keycaps"
        aria-hidden="true"
        class="js-only pointer-events-none absolute bottom-4 left-1/2 hidden -translate-x-1/2 gap-1.5 font-mono text-xs md:flex"
      >
        <kbd data-key="ArrowLeft" class="keycap rounded border border-line px-2 py-0.5 text-mist"
          >&larr;</kbd
        >
        <kbd data-key="ArrowRight" class="keycap rounded border border-line px-2 py-0.5 text-mist"
          >&rarr;</kbd
        >
      </div>
    </div>
  </body>
</html>

<style>
  .rail {
    view-transition-name: rail;
  }
  @media (prefers-reduced-motion: no-preference) {
    .nav-item {
      transition: color 150ms ease-out;
    }
  }
  .nav-item:hover {
    color: var(--ink);
  }
  .nav-item[aria-current='page'] {
    color: var(--ink);
    font-weight: 500;
  }
  .nav-item[aria-current='page'] .num {
    color: var(--signal-text);
  }
  /* FR-09: a pressed keycap lights to the signal accent for 150ms. */
  .keycap.lit {
    border-color: var(--signal);
    color: var(--ink);
  }
  @media (prefers-reduced-motion: no-preference) {
    .keycap {
      transition:
        color 150ms ease-out,
        border-color 150ms ease-out;
    }
  }
</style>

<script>
  import { navigate } from 'astro:transitions/client';
  import { PANELS, panelIndex } from '../lib/panels';

  // --- Directional slides (FR-04). Direction derives from the panel
  // sequence and is stamped on the incoming document so the
  // view-transition CSS can pick the matching keyframes. Computed inside
  // before-swap (which carries from/to itself) so overlapping
  // navigations cannot stamp each other's direction.
  document.addEventListener('astro:before-swap', (e) => {
    const ev = e as Event & { from: URL; to: URL; newDocument: Document };
    const from = panelIndex(ev.from.pathname);
    const to = panelIndex(ev.to.pathname);
    if (from !== -1 && to !== -1 && from !== to) {
      ev.newDocument.documentElement.dataset.navDirection = to > from ? 'forward' : 'back';
    } else {
      delete ev.newDocument.documentElement.dataset.navDirection;
    }
  });

  // --- Arrow-key navigation between top-level panels (FR-05).
  // Inputs that arrive while a panel transition is already in flight are
  // ignored rather than aborting it mid-slide — spamming keys or swipes
  // produces clean sequential transitions instead of thrash.
  let navInFlight = false;
  document.addEventListener('astro:before-preparation', () => {
    navInFlight = true;
  });
  document.addEventListener('astro:page-load', () => {
    navInFlight = false;
  });

  // FR-09: flash the matching keycap for 150ms on a real keypress.
  let keycapTimer = 0;
  function flashKeycap(key: string): void {
    const cap = document.querySelector(`.keycap[data-key="${key}"]`);
    if (!cap) return;
    cap.classList.add('lit');
    window.clearTimeout(keycapTimer);
    keycapTimer = window.setTimeout(() => cap.classList.remove('lit'), 150);
  }

  document.addEventListener('keydown', (e) => {
    if (e.defaultPrevented || e.altKey || e.ctrlKey || e.metaKey || e.shiftKey) return;
    if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
    const target = e.target as HTMLElement | null;
    if (
      target &&
      (target.tagName === 'INPUT' ||
        target.tagName === 'TEXTAREA' ||
        target.tagName === 'SELECT' ||
        target.isContentEditable)
    ) {
      return;
    }
    // Light the keycap on the actual press, even at a boundary or mid-slide.
    flashKeycap(e.key);
    if (navInFlight) return;
    const current = panelIndex(location.pathname);
    if (current === -1) return;
    const next = current + (e.key === 'ArrowRight' ? 1 : -1);
    if (next < 0 || next >= PANELS.length) return;
    navigate(PANELS[next].href);
  });

  // --- Horizontal swipe on touch (FR-05). A leftward swipe advances, matching
  // the slide direction of the panels.
  let touchStartX: number | null = null;
  let touchStartY: number | null = null;

  document.addEventListener(
    'touchstart',
    (e) => {
      if (e.touches.length !== 1) {
        touchStartX = null;
        return;
      }
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    },
    { passive: true }
  );

  document.addEventListener(
    'touchend',
    (e) => {
      if (touchStartX === null || touchStartY === null) return;
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;
      touchStartX = null;
      touchStartY = null;
      if (navInFlight) return;
      if (Math.abs(dx) < 48 || Math.abs(dx) < 2 * Math.abs(dy)) return;
      const current = panelIndex(location.pathname);
      if (current === -1) return;
      const next = current + (dx < 0 ? 1 : -1);
      if (next < 0 || next >= PANELS.length) return;
      navigate(PANELS[next].href);
    },
    { passive: true }
  );

  // --- Theme toggle (FR-08): auto → light → dark, persisted in localStorage.
  // One instance lives in the desktop rail, one in the mobile settings
  // menu; both are class-targeted and delegated so listeners survive
  // view-transition swaps.
  const THEMES = ['auto', 'light', 'dark'];

  function currentTheme(): string {
    const stored = localStorage.getItem('theme');
    return stored === 'light' || stored === 'dark' ? stored : 'auto';
  }

  function syncToggleLabels(): void {
    const label = `theme: ${currentTheme()}`;
    for (const btn of document.querySelectorAll('.theme-toggle')) {
      btn.textContent = label;
    }
  }

  function closeSettingsMenu(): void {
    const menu = document.getElementById('settings-menu');
    const btn = document.getElementById('settings-toggle');
    if (menu) menu.hidden = true;
    if (btn) btn.setAttribute('aria-expanded', 'false');
  }

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement | null;
    if (!target) return;

    if (target.closest('.theme-toggle')) {
      const next = THEMES[(THEMES.indexOf(currentTheme()) + 1) % THEMES.length];
      if (next === 'auto') {
        localStorage.removeItem('theme');
        delete document.documentElement.dataset.theme;
      } else {
        localStorage.setItem('theme', next);
        document.documentElement.dataset.theme = next;
      }
      syncToggleLabels();
      return;
    }

    // Mobile settings disclosure (secondary menu below 768px).
    if (target.closest('#settings-toggle')) {
      const menu = document.getElementById('settings-menu');
      const btn = document.getElementById('settings-toggle');
      if (!menu || !btn) return;
      const open = menu.hidden;
      menu.hidden = !open;
      btn.setAttribute('aria-expanded', String(open));
      return;
    }

    if (!target.closest('#settings-menu')) closeSettingsMenu();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSettingsMenu();
  });

  document.addEventListener('astro:page-load', syncToggleLabels);
</script>
