---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { PANELS, panelIndex } from '../lib/panels';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const current = panelIndex(Astro.url.pathname);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      // FR-08: apply the stored theme before first paint, and re-apply after
      // every view-transition swap (the swap replaces <html> attributes).
      (() => {
        const apply = () => {
          const stored = localStorage.getItem('theme');
          if (stored === 'light' || stored === 'dark') {
            document.documentElement.dataset.theme = stored;
          } else {
            delete document.documentElement.dataset.theme;
          }
        };
        apply();
        document.addEventListener('astro:after-swap', apply);
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-surface focus:px-4 focus:py-2 focus:text-ink"
      >Skip to content</a
    >
    <div class="flex h-dvh flex-col-reverse md:flex-row">
      <nav
        class="rail flex h-14 shrink-0 items-stretch border-t border-line md:h-auto md:w-[200px] md:flex-col md:border-t-0 md:border-r md:p-6"
        aria-label="Main"
      >
        <a href="/" class="brand hidden items-center gap-2 md:flex">
          <svg viewBox="0 0 32 32" class="h-4 w-4" aria-hidden="true">
            <circle cx="12" cy="16" r="6" fill="var(--signal)"></circle>
            <path
              d="M18 16h10"
              stroke="var(--signal)"
              stroke-width="3"
              stroke-linecap="round"></path>
          </svg>
          <span class="font-mono text-xs tracking-[0.08em] text-ink">philsanjaya.dev</span>
        </a>
        <ol class="flex flex-1 items-stretch justify-around md:mt-10 md:flex-col md:justify-start md:gap-2">
          {
            PANELS.map((p, i) => (
              <li class="flex flex-1 md:flex-none">
                <a
                  href={p.href}
                  aria-current={i === current ? 'page' : undefined}
                  class="nav-item flex flex-1 flex-col items-center justify-center gap-0.5 text-mist md:flex-row md:justify-start md:gap-3 md:py-1"
                >
                  <span class="num font-mono text-[10px] md:text-xs">{p.num}</span>
                  <span class="text-xs md:text-sm">{p.label}</span>
                </a>
              </li>
            ))
          }
        </ol>
        <div class="hidden md:block">
          <button
            id="theme-toggle"
            type="button"
            class="cursor-pointer font-mono text-xs text-mist transition-colors duration-150 ease-out hover:text-ink"
            >theme: auto</button
          >
          <p class="mt-3 font-mono text-xs text-mist" aria-hidden="true">&larr; &rarr; move</p>
        </div>
      </nav>
      <main id="main" class="stage min-h-0 min-w-0 flex-1 overflow-hidden" transition:name="stage">
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  .rail {
    view-transition-name: rail;
  }
  .nav-item {
    transition: color 150ms ease-out;
  }
  .nav-item:hover {
    color: var(--ink);
  }
  .nav-item[aria-current='page'] {
    color: var(--ink);
    font-weight: 500;
  }
  .nav-item[aria-current='page'] .num {
    color: var(--signal);
  }
  :focus-visible {
    outline: 2px solid var(--signal);
    outline-offset: 2px;
  }
</style>

<script>
  import { navigate } from 'astro:transitions/client';
  import { PANELS, panelIndex } from '../lib/panels';

  // --- Directional slides (FR-04). Direction is computed from the panel
  // sequence and stamped on the incoming document so the view-transition
  // CSS can pick the matching keyframes.
  let direction: 'forward' | 'back' | null = null;

  document.addEventListener('astro:before-preparation', (e) => {
    const ev = e as Event & { from: URL; to: URL };
    const from = panelIndex(ev.from.pathname);
    const to = panelIndex(ev.to.pathname);
    direction = from !== -1 && to !== -1 && from !== to ? (to > from ? 'forward' : 'back') : null;
  });

  document.addEventListener('astro:before-swap', (e) => {
    const ev = e as Event & { newDocument: Document };
    if (direction) {
      ev.newDocument.documentElement.dataset.navDirection = direction;
    } else {
      delete ev.newDocument.documentElement.dataset.navDirection;
    }
  });

  // --- Arrow-key navigation between top-level panels (FR-05).
  document.addEventListener('keydown', (e) => {
    if (e.defaultPrevented || e.altKey || e.ctrlKey || e.metaKey || e.shiftKey) return;
    if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
    const target = e.target as HTMLElement | null;
    if (
      target &&
      (target.tagName === 'INPUT' ||
        target.tagName === 'TEXTAREA' ||
        target.tagName === 'SELECT' ||
        target.isContentEditable)
    ) {
      return;
    }
    const current = panelIndex(location.pathname);
    if (current === -1) return;
    const next = current + (e.key === 'ArrowRight' ? 1 : -1);
    if (next < 0 || next >= PANELS.length) return;
    navigate(PANELS[next].href);
  });

  // --- Horizontal swipe on touch (FR-05). A leftward swipe advances, matching
  // the slide direction of the panels.
  let touchStartX: number | null = null;
  let touchStartY: number | null = null;

  document.addEventListener(
    'touchstart',
    (e) => {
      if (e.touches.length !== 1) {
        touchStartX = null;
        return;
      }
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    },
    { passive: true }
  );

  document.addEventListener(
    'touchend',
    (e) => {
      if (touchStartX === null || touchStartY === null) return;
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;
      touchStartX = null;
      touchStartY = null;
      if (Math.abs(dx) < 48 || Math.abs(dx) < 2 * Math.abs(dy)) return;
      const current = panelIndex(location.pathname);
      if (current === -1) return;
      const next = current + (dx < 0 ? 1 : -1);
      if (next < 0 || next >= PANELS.length) return;
      navigate(PANELS[next].href);
    },
    { passive: true }
  );

  // --- Theme toggle (FR-08): auto → light → dark, persisted in localStorage.
  // Delegated so the listener survives view-transition swaps.
  const THEMES = ['auto', 'light', 'dark'];

  function currentTheme(): string {
    const stored = localStorage.getItem('theme');
    return stored === 'light' || stored === 'dark' ? stored : 'auto';
  }

  function syncToggleLabel(): void {
    const btn = document.getElementById('theme-toggle');
    if (btn) btn.textContent = `theme: ${currentTheme()}`;
  }

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement | null;
    if (!target || !target.closest('#theme-toggle')) return;
    const next = THEMES[(THEMES.indexOf(currentTheme()) + 1) % THEMES.length];
    if (next === 'auto') {
      localStorage.removeItem('theme');
      delete document.documentElement.dataset.theme;
    } else {
      localStorage.setItem('theme', next);
      document.documentElement.dataset.theme = next;
    }
    syncToggleLabel();
  });

  document.addEventListener('astro:page-load', syncToggleLabel);
</script>
